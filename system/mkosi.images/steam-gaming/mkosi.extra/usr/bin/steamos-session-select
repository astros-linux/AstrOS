#!/usr/bin/bash

# Hook for custom OS script
for GAMESCOPE_SESSION_SCRIPT in \
    "/usr/lib/os-session-select" \
    "/usr/libexec/os-session-select"
do
    if [ -f "$GAMESCOPE_SESSION_SCRIPT" ]; then
        exec "${GAMESCOPE_SESSION_SCRIPT}" "$@"
    fi
done

# Close steam if no script was found
steam -shutdown
