#!/usr/bin/bash

# Hook for custom OS branch script
for STEAMOS_BRANCH_SCRIPT in \
    "/usr/lib/os-branch-select" \
    "/usr/libexec/os-branch-select"
do
    if [ -f "$STEAMOS_BRANCH_SCRIPT" ]; then
        exec "${STEAMOS_BRANCH_SCRIPT}" "$@"
    fi
done

# Default message if no script found
echo "No branches available"
