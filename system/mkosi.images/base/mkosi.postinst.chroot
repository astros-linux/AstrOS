#!/bin/bash
set -e

# gen locales
locale-gen

# branding
(
  . /usr/lib/os-release
  cat >/usr/lib/os-release <<EOF
NAME="AstrOS"
PRETTY_NAME="AstrOS"
ID="astros"
ID_LIKE="$ID"
VERSION_ID="$IMAGE_VERSION"
ANSI_COLOR="38;2;185;113;251"
HOME_URL="https://astros-linux.org"
EOF
)

# https://wiki.archlinux.org/title/COSMIC#SSH_AUTH_SOCK_not_set
systemctl enable --user gcr-ssh-agent.socket
