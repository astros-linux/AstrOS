#!/bin/bash
set -e

# gen locales
locale-gen

# branding
(
  . /usr/lib/os-release
  cat >/usr/lib/os-release <<EOF
NAME="AstrOS"
PRETTY_NAME="AstrOS"
ID="astros"
ID_LIKE="$ID"
ANSI_COLOR="38;2;23;147;209"
HOME_URL="https://astros-linux.org"
EOF
)

# required for podman
chmod u+s /usr/bin/newuidmap /usr/bin/newgidmap
