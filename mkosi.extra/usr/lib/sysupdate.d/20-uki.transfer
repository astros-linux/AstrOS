[Transfer]
ProtectVersion=%A
# during testing only
Verify=no

[Source]
Type=url-file
Path=https://dl.astros-linux.org/
MatchPattern=%M_@v_%a.efi

[Target]
Type=regular-file
Path=/EFI/Linux
PathRelativeTo=boot
MatchPattern=%M_@v_%a+@l-@d.efi \
             %M_@v_%a+@l.efi \
             %M_@v_%a.efi \
             %M_@v+@l-@d.efi \
             %M_@v+@l.efi \
             %M_@v.efi
Mode=0600
TriesLeft=3
TriesDone=0
InstancesMax=2
